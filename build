#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_BIN="${PYTHON_BIN:-python3}"
VENV_DIR="${VENV_DIR:-$ROOT_DIR/.venv}"
CONFIG_PATH="$ROOT_DIR/config/build-deploy.yaml"
OUTPUT_DIR="$ROOT_DIR/artifacts/release"
RUNTIME_CONFIG_OUTPUT="$ROOT_DIR/artifacts/device/config.json"
HOST="0.0.0.0"
PORT="8080"
DEVICE_PORT=""
COMMAND=""
VERBOSE=0
USE_VENV=1
WIFI_SSID="${VIVIPI_WIFI_SSID:-}"
WIFI_PASSWORD="${VIVIPI_WIFI_PASSWORD:-}"
SERVICE_BASE_URL="${VIVIPI_SERVICE_BASE_URL:-}"

usage() {
    cat <<'EOF'
Usage: ./build [command] [options]

Running ./build with no command is equivalent to: ./build ci

Commands that render or package device config require:
    VIVIPI_WIFI_SSID, VIVIPI_WIFI_PASSWORD, and VIVIPI_SERVICE_BASE_URL
You can provide them as environment variables or with:
    --wifi-ssid, --wifi-password, and --service-base-url

Commands:
  ci               Install dependencies, run Ruff, run pytest, and build firmware assets
  install          Create the local virtual environment and install dev dependencies
  lint             Run Ruff
  test             Run pytest
  coverage         Run pytest with branch coverage output
  render-config    Render artifacts/device/config.json from the build config
  build-firmware   Build the zipped firmware bundle into artifacts/release
  deploy           Build the firmware bundle and copy it to the Pico via mpremote
  release-assets   Build Python distributions and the firmware release bundle
  service          Run the default ADB-backed Vivi Service
  all              Alias for ci
  help             Show this help text

Options:
  -c, --config PATH          Build/deploy config path
  -o, --output-dir PATH      Release output directory
  --runtime-config PATH      Runtime config JSON output path
  --device-port PATH         Serial or USB path for mpremote deploy
  --host HOST                Host for the Vivi Service
  --port PORT                Port for the Vivi Service
  --python PATH              Python executable to use when not in venv
  --venv PATH                Virtualenv directory
  --no-venv                  Use the current Python environment directly
  --wifi-ssid VALUE          Override VIVIPI_WIFI_SSID for this invocation
  --wifi-password VALUE      Override VIVIPI_WIFI_PASSWORD for this invocation
  --service-base-url VALUE   Override VIVIPI_SERVICE_BASE_URL for this invocation
  -v, --verbose              Print commands before running them
  -h, --help                 Show this help text
EOF
}

log() {
    printf '%s\n' "$*"
}

run_cmd() {
    if [[ "$VERBOSE" -eq 1 ]]; then
        log "+ $*"
    fi
    "$@"
}

ensure_venv() {
    if [[ "$USE_VENV" -eq 0 ]]; then
        return
    fi

    if [[ ! -d "$VENV_DIR" ]]; then
        run_cmd "$PYTHON_BIN" -m venv "$VENV_DIR"
    fi
}

python_cmd() {
    if [[ "$USE_VENV" -eq 1 ]]; then
        printf '%s\n' "$VENV_DIR/bin/python"
        return
    fi
    printf '%s\n' "$PYTHON_BIN"
}

ensure_dependencies() {
    ensure_venv
    local python_path
    python_path="$(python_cmd)"
    run_cmd "$python_path" -m pip install --upgrade pip
    run_cmd "$python_path" -m pip install -e '.[dev]'
}

with_wifi_env() {
    if [[ -n "$WIFI_SSID" ]]; then
        export VIVIPI_WIFI_SSID="$WIFI_SSID"
    fi
    if [[ -n "$WIFI_PASSWORD" ]]; then
        export VIVIPI_WIFI_PASSWORD="$WIFI_PASSWORD"
    fi
    if [[ -n "$SERVICE_BASE_URL" ]]; then
        export VIVIPI_SERVICE_BASE_URL="$SERVICE_BASE_URL"
    fi
}

run_python_module() {
    local python_path
    python_path="$(python_cmd)"
    run_cmd "$python_path" -m "$@"
}

require_runtime_env() {
    local missing=()

    if [[ -z "$WIFI_SSID" ]]; then
        missing+=("VIVIPI_WIFI_SSID")
    fi
    if [[ -z "$WIFI_PASSWORD" ]]; then
        missing+=("VIVIPI_WIFI_PASSWORD")
    fi
    if [[ -z "$SERVICE_BASE_URL" ]]; then
        missing+=("VIVIPI_SERVICE_BASE_URL")
    fi

    if [[ ${#missing[@]} -eq 0 ]]; then
        return
    fi

    log "Missing required runtime configuration: ${missing[*]}"
    log "Set them in the environment or pass --wifi-ssid, --wifi-password, and --service-base-url."
    log "Example:"
    log "  VIVIPI_WIFI_SSID=wifi VIVIPI_WIFI_PASSWORD=secret VIVIPI_SERVICE_BASE_URL=http://192.168.1.10:8080/checks ./build $COMMAND"
    exit 2
}

run_ci_workflow() {
    ensure_dependencies
    run_python_module ruff check .
    run_python_module pytest
    require_runtime_env
    with_wifi_env
    run_python_module vivipi.tooling.build_deploy build-firmware --config "$CONFIG_PATH" --output-dir "$OUTPUT_DIR"
}

build_firmware_bundle() {
    ensure_dependencies
    require_runtime_env
    with_wifi_env
    run_python_module vivipi.tooling.build_deploy build-firmware --config "$CONFIG_PATH" --output-dir "$OUTPUT_DIR"
}

render_runtime_config() {
    ensure_dependencies
    require_runtime_env
    with_wifi_env
    run_python_module vivipi.tooling.build_deploy render-config --config "$CONFIG_PATH" --output "$RUNTIME_CONFIG_OUTPUT"
}

build_python_distributions() {
    ensure_dependencies
    local python_path
    python_path="$(python_cmd)"
    run_cmd "$python_path" -m build
}

deploy_bundle() {
    ensure_dependencies
    require_runtime_env
    with_wifi_env
    local args=(vivipi.tooling.build_deploy deploy-firmware --config "$CONFIG_PATH" --output-dir "$OUTPUT_DIR")
    if [[ -n "$DEVICE_PORT" ]]; then
        args+=(--port "$DEVICE_PORT")
    fi
    run_python_module "${args[@]}"
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            install|lint|test|coverage|ci|render-config|build-firmware|release-assets|deploy|service|all|help)
                COMMAND="$1"
                shift
                ;;
            -c|--config)
                CONFIG_PATH="$2"
                shift 2
                ;;
            -o|--output-dir)
                OUTPUT_DIR="$2"
                shift 2
                ;;
            --runtime-config)
                RUNTIME_CONFIG_OUTPUT="$2"
                shift 2
                ;;
            --host)
                HOST="$2"
                shift 2
                ;;
            --port)
                PORT="$2"
                shift 2
                ;;
            --device-port)
                DEVICE_PORT="$2"
                shift 2
                ;;
            --python)
                PYTHON_BIN="$2"
                shift 2
                ;;
            --venv)
                VENV_DIR="$2"
                shift 2
                ;;
            --no-venv)
                USE_VENV=0
                shift
                ;;
            --wifi-ssid)
                WIFI_SSID="$2"
                shift 2
                ;;
            --wifi-password)
                WIFI_PASSWORD="$2"
                shift 2
                ;;
            --service-base-url)
                SERVICE_BASE_URL="$2"
                shift 2
                ;;
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -h|--help)
                COMMAND="help"
                shift
                ;;
            *)
                log "Unknown argument: $1"
                usage
                exit 2
                ;;
        esac
    done

    if [[ -z "$COMMAND" ]]; then
        COMMAND="ci"
    fi
}

main() {
    cd "$ROOT_DIR"
    parse_args "$@"

    case "$COMMAND" in
        install)
            ensure_dependencies
            ;;
        lint)
            ensure_dependencies
            run_python_module ruff check .
            ;;
        test)
            ensure_dependencies
            run_python_module pytest
            ;;
        coverage)
            ensure_dependencies
            run_python_module pytest --cov=src/vivipi --cov-branch --cov-report=term-missing --cov-report=xml
            ;;
        ci)
            run_ci_workflow
            ;;
        render-config)
            render_runtime_config
            ;;
        build-firmware)
            build_firmware_bundle
            ;;
        release-assets)
            build_python_distributions
            build_firmware_bundle
            ;;
        deploy)
            deploy_bundle
            ;;
        service)
            ensure_dependencies
            run_python_module vivipi.services.adb_service --host "$HOST" --port "$PORT"
            ;;
        all)
            run_ci_workflow
            ;;
        help)
            usage
            ;;
        *)
            log "Unsupported command: $COMMAND"
            exit 2
            ;;
    esac
}

main "$@"
